<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 浅色主题色值 -->

    <SolidColorBrush x:Key="Brush.BackgroundDeep" Color="#F3F4F6" />
    <SolidColorBrush x:Key="Brush.BackgroundPrimary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.BackgroundSecondary" Color="#F9FAFB" />
    <SolidColorBrush x:Key="Brush.BorderPrimary" Color="#E5E7EB" />
    <SolidColorBrush x:Key="Brush.BorderSecondary" Color="#D1D5DB" />
    <SolidColorBrush x:Key="Brush.ForegroundPrimary" Color="#111827" />
    <SolidColorBrush x:Key="Brush.ForegroundSecondary" Color="#374151" />
    <SolidColorBrush x:Key="Brush.ForegroundTertiary" Color="#6B7280" />
    <SolidColorBrush x:Key="Brush.ForegroundMuted" Color="#9CA3AF" />
    <SolidColorBrush x:Key="Brush.ForegroundSubtle" Color="#D1D5DB" />

    <LinearGradientBrush x:Key="Brush.UserBubble" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2563EB" Offset="0" />
        <GradientStop Color="#4F46E5" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Brush.SendBtn" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2563EB" Offset="0" />
        <GradientStop Color="#4F46E5" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Brush.SendBtnHover" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#3B82F6" Offset="0" />
        <GradientStop Color="#6366F1" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="Brush.AccentStart" Color="#2563EB" />
    <SolidColorBrush x:Key="Brush.AccentEnd" Color="#4F46E5" />
    <LinearGradientBrush x:Key="Brush.AccentBtn" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2563EB" Offset="0" />
        <GradientStop Color="#4F46E5" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Brush.InputCaret" Color="#2563EB" />

    <SolidColorBrush x:Key="Brush.StatusOnline" Color="#16A34A" />
    <SolidColorBrush x:Key="Brush.StatusOffline" Color="#D97706" />

    <!-- 微信风格气泡 + 聊天背景 -->
    <SolidColorBrush x:Key="Brush.ChatBackground" Color="#EDEDED" />
    <SolidColorBrush x:Key="Brush.UserBubbleWechat" Color="#95EC69" />
    <SolidColorBrush x:Key="Brush.AssistantBubble" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.AssistantBubbleBorder" Color="#E0E0E0" />
    <SolidColorBrush x:Key="Brush.UserBubbleText" Color="#000000" />
    <SolidColorBrush x:Key="Brush.BubbleTimestamp" Color="#B0B0B0" />

    <!-- ═══ Markdown 元素配色（浅色） ═══ -->
    <SolidColorBrush x:Key="Brush.MdHeading" Color="#1E40AF" />       <!-- 标题：深蓝 -->
    <SolidColorBrush x:Key="Brush.MdHeading2" Color="#6D28D9" />      <!-- 子标题：紫色 -->
    <SolidColorBrush x:Key="Brush.MdQuoteFg" Color="#4B5563" />       <!-- 引用文字 -->
    <SolidColorBrush x:Key="Brush.MdQuoteBg" Color="#F3F4F6" />       <!-- 引用背景 -->
    <SolidColorBrush x:Key="Brush.MdQuoteBorder" Color="#2563EB" />   <!-- 引用左边框 -->
    <SolidColorBrush x:Key="Brush.MdCodeFg" Color="#065F46" />        <!-- 代码文字：深绿 -->
    <SolidColorBrush x:Key="Brush.MdCodeBg" Color="#F1F5F9" />        <!-- 代码背景 -->
    <SolidColorBrush x:Key="Brush.MdLink" Color="#2563EB" />           <!-- 链接：蓝色 -->
    <SolidColorBrush x:Key="Brush.MdTableBorder" Color="#D1D5DB" />    <!-- 表格线 -->
    <SolidColorBrush x:Key="Brush.MdTableHeader" Color="#E5E7EB" />    <!-- 表头背景 -->
    <SolidColorBrush x:Key="Brush.MdBold" Color="#111827" />           <!-- 粗体加强 -->
    <SolidColorBrush x:Key="Brush.MdRule" Color="#D1D5DB" />           <!-- 分割线 -->

</ResourceDictionary>
