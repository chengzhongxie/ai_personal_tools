<Window x:Class="PersonalAssistant.Features.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="440" Height="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Background="#131720">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold"
                   Foreground="#E8ECF1" Text="设置"
                   Margin="0,0,0,16" />

        <!-- Settings Content -->
        <StackPanel Grid.Row="1">
            <!-- AI Model Section -->
            <TextBlock FontSize="13" FontWeight="SemiBold"
                       Foreground="#9CA3AF" Text="AI 模型配置"
                       Margin="0,0,0,10" />

            <TextBlock Text="API Key" FontSize="12"
                       Foreground="#6B7280" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="ApiKeyPasswordBox" Grid.Column="0"
                             VerticalAlignment="Center" Padding="8,6"
                             FontSize="12"
                             Background="#1A1F2E" Foreground="#E8ECF1"
                             BorderBrush="#2A3040"
                             CaretBrush="#3B82F6"
                             PasswordChanged="ApiKeyPasswordBox_PasswordChanged" />
                <TextBox x:Name="ApiKeyTextBox" Grid.Column="0"
                         VerticalAlignment="Center" Padding="8,6"
                         FontSize="12"
                         Background="#1A1F2E" Foreground="#E8ECF1"
                         BorderBrush="#2A3040"
                         CaretBrush="#3B82F6"
                         Visibility="Collapsed"
                         TextChanged="ApiKeyTextBox_TextChanged" />
                <Button Grid.Column="1" x:Name="ToggleApiKeyBtn"
                        Content="显示" Width="46" Padding="6,2"
                        Margin="8,0,0,0" FontSize="11"
                        VerticalAlignment="Center"
                        Background="#2A3040" Foreground="#9CA3AF"
                        BorderThickness="0" Cursor="Hand"
                        Click="ToggleApiKeyVisibility_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>

            <TextBlock Text="模型名称" FontSize="12"
                       Foreground="#6B7280" Margin="0,0,0,4" />
            <TextBox x:Name="ModelTextBox" Margin="0,0,0,12"
                     Padding="8,6" FontSize="12"
                     Background="#1A1F2E" Foreground="#E8ECF1"
                     BorderBrush="#2A3040"
                     CaretBrush="#3B82F6" />

            <TextBlock Text="API 端点" FontSize="12"
                       Foreground="#6B7280" Margin="0,0,0,4" />
            <TextBox x:Name="EndpointTextBox" Margin="0,0,0,16"
                     Padding="8,6" FontSize="12"
                     Background="#1A1F2E" Foreground="#E8ECF1"
                     BorderBrush="#2A3040"
                     CaretBrush="#3B82F6" />

            <!-- Separator -->
            <Border Height="1" Background="#2A3040" Margin="0,0,0,14" />

            <!-- System Section -->
            <TextBlock FontSize="13" FontWeight="SemiBold"
                       Foreground="#9CA3AF" Text="系统"
                       Margin="0,0,0,10" />

            <CheckBox x:Name="AutoStartCheckBox" Content="开机自启动"
                      FontSize="12" Foreground="#D1D5DB"
                      VerticalAlignment="Center" />

            <TextBlock FontSize="11" Foreground="#6B7280"
                       Margin="0,6,0,0"
                       Text="AI 配置修改后需重启应用生效" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Width="80" Padding="8,6"
                    Margin="0,0,10,0"
                    Background="#2A3040" Foreground="#D1D5DB"
                    BorderThickness="0" FontSize="12" Cursor="Hand"
                    Click="Cancel_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="保存" Width="80" Padding="8,6"
                    FontSize="12" FontWeight="SemiBold"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="Save_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" CornerRadius="6"
                                Padding="18,6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#3B82F6" Offset="0" />
                                    <GradientStop Color="#6366F1" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
