<Window x:Class="PersonalAssistant.Features.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PersonalAssistant.Infrastructure.Common.Controls"
        Title="设置"
        Width="440" SizeToContent="Height" MaxHeight="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Background="{DynamicResource Brush.BackgroundPrimary}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.ForegroundPrimary}" Text="设置"
                   Margin="0,0,0,16" />

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- AI Model Section -->
            <TextBlock FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.ForegroundTertiary}" Text="AI 模型配置"
                       Margin="0,0,0,10" />

            <TextBlock Text="提供商预设" FontSize="12"
                       Foreground="{DynamicResource Brush.ForegroundMuted}" Margin="0,0,0,4" />
            <ComboBox x:Name="ProviderPresetComboBox" Margin="0,0,0,12"
                      Padding="8,6" FontSize="12"
                      Background="{DynamicResource Brush.BackgroundSecondary}" Foreground="{DynamicResource Brush.ForegroundPrimary}"
                      BorderBrush="{DynamicResource Brush.BorderSecondary}"
                      SelectionChanged="ProviderPreset_SelectionChanged" />

            <TextBlock Text="API Key" FontSize="12"
                       Foreground="{DynamicResource Brush.ForegroundMuted}" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="ApiKeyPasswordBox" Grid.Column="0"
                             VerticalAlignment="Center" Padding="8,6"
                             FontSize="12"
                             Background="{DynamicResource Brush.BackgroundSecondary}" Foreground="{DynamicResource Brush.ForegroundPrimary}"
                             BorderBrush="{DynamicResource Brush.BorderSecondary}"
                             CaretBrush="{DynamicResource Brush.InputCaret}"
                             PasswordChanged="ApiKeyPasswordBox_PasswordChanged" />
                <TextBox x:Name="ApiKeyTextBox" Grid.Column="0"
                         VerticalAlignment="Center" Padding="8,6"
                         FontSize="12"
                         Background="{DynamicResource Brush.BackgroundSecondary}" Foreground="{DynamicResource Brush.ForegroundPrimary}"
                         BorderBrush="{DynamicResource Brush.BorderSecondary}"
                         CaretBrush="{DynamicResource Brush.InputCaret}"
                         Visibility="Collapsed"
                         TextChanged="ApiKeyTextBox_TextChanged" />
                <Button Grid.Column="1" x:Name="ToggleApiKeyBtn"
                        Content="显示" Width="46" Padding="6,2"
                        Margin="8,0,0,0" FontSize="11"
                        VerticalAlignment="Center"
                        Background="{DynamicResource Brush.BorderSecondary}" Foreground="{DynamicResource Brush.ForegroundTertiary}"
                        BorderThickness="0" Cursor="Hand"
                        Click="ToggleApiKeyVisibility_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>

            <TextBlock Text="模型名称" FontSize="12"
                       Foreground="{DynamicResource Brush.ForegroundMuted}" Margin="0,0,0,4" />
            <TextBox x:Name="ModelTextBox" Margin="0,0,0,4"
                     Padding="8,6" FontSize="12"
                     Background="{DynamicResource Brush.BackgroundSecondary}" Foreground="{DynamicResource Brush.ForegroundPrimary}"
                     BorderBrush="{DynamicResource Brush.BorderSecondary}"
                     CaretBrush="{DynamicResource Brush.InputCaret}" />
            <TextBlock FontSize="10" Foreground="{DynamicResource Brush.ForegroundMuted}"
                       Margin="0,0,0,10"
                       Text="请根据所选提供商填写正确的模型ID" />

            <TextBlock Text="API 端点" FontSize="12"
                       Foreground="{DynamicResource Brush.ForegroundMuted}" Margin="0,0,0,4" />
            <TextBox x:Name="EndpointTextBox" Margin="0,0,0,10"
                     Padding="8,6" FontSize="12"
                     Background="{DynamicResource Brush.BackgroundSecondary}" Foreground="{DynamicResource Brush.ForegroundPrimary}"
                     BorderBrush="{DynamicResource Brush.BorderSecondary}"
                     CaretBrush="{DynamicResource Brush.InputCaret}" />

            <!-- 测试连接 -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="TestBtn" Grid.Column="0"
                        Content="测试连接" Padding="12,6"
                        FontSize="12" Cursor="Hand"
                        Background="{DynamicResource Brush.BorderSecondary}" Foreground="{DynamicResource Brush.ForegroundSecondary}"
                        BorderThickness="0"
                        Click="TestConnection_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
                <TextBlock x:Name="TestStatus" Grid.Column="1"
                           FontSize="12" Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.ForegroundMuted}" />
            </Grid>

            <!-- Separator -->
            <Border Height="1" Background="{DynamicResource Brush.BorderSecondary}" Margin="0,0,0,14" />

            <!-- System Section -->
            <TextBlock FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.ForegroundTertiary}" Text="系统"
                       Margin="0,0,0,10" />

            <CheckBox x:Name="AutoStartCheckBox" Content="开机自启动"
                      FontSize="12" Foreground="{DynamicResource Brush.ForegroundSecondary}"
                      VerticalAlignment="Center" />

            <!-- Custom System Prompt -->
            <Border Height="1" Background="{DynamicResource Brush.BorderSecondary}" Margin="0,14,0,14" />

            <TextBlock FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.ForegroundTertiary}" Text="自定义系统提示词"
                       Margin="0,0,0,10" />

            <TextBox x:Name="CustomPromptTextBox"
                     Padding="8,6" FontSize="12"
                     MinHeight="80"
                     MaxHeight="200"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Background="{DynamicResource Brush.BackgroundSecondary}" Foreground="{DynamicResource Brush.ForegroundPrimary}"
                     BorderBrush="{DynamicResource Brush.BorderSecondary}"
                     CaretBrush="{DynamicResource Brush.InputCaret}" />

            <TextBlock FontSize="10" Foreground="{DynamicResource Brush.ForegroundMuted}"
                       Margin="0,4,0,0"
                       Text="自定义 AI 助手的行为指令。留空则使用默认系统提示词。修改后需重启应用生效。" />

            <!-- Hotkey Configuration -->
            <Border Height="1" Background="{DynamicResource Brush.BorderSecondary}" Margin="0,14,0,14" />

            <TextBlock FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.ForegroundTertiary}" Text="快捷键"
                       Margin="0,0,0,10" />

            <TextBlock Text="显示/隐藏主窗口" FontSize="12"
                       Foreground="{DynamicResource Brush.ForegroundMuted}" Margin="0,0,0,4" />
            <controls:HotkeyCaptureBox x:Name="MainHotkeyBox"
                Margin="0,0,0,12" />

            <TextBlock Text="发送选中文本给 AI" FontSize="12"
                       Foreground="{DynamicResource Brush.ForegroundMuted}" Margin="0,0,0,4" />
            <controls:HotkeyCaptureBox x:Name="SelectTextHotkeyBox"
                Margin="0,0,0,6" />

            <TextBlock FontSize="10" Foreground="{DynamicResource Brush.ForegroundMuted}"
                       Margin="0,0,0,0"
                       Text="点击输入框后按下组合键即可修改" />

            <!-- Knowledge Base -->
            <Border Height="1" Background="{DynamicResource Brush.BorderSecondary}" Margin="0,14,0,14" />

            <TextBlock FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.ForegroundTertiary}" Text="知识库"
                       Margin="0,0,0,10" />

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="KbDirTextBox" Grid.Column="0"
                         Padding="8,6" FontSize="12"
                         Background="{DynamicResource Brush.BackgroundSecondary}" Foreground="{DynamicResource Brush.ForegroundPrimary}"
                         BorderBrush="{DynamicResource Brush.BorderSecondary}" CaretBrush="{DynamicResource Brush.InputCaret}"
                         IsReadOnly="True"
                         Text="未选择目录" />
                <Button Grid.Column="1" x:Name="BrowseKbDirBtn"
                        Content="浏览" Width="60" Padding="6,2"
                        Margin="8,0,0,0" FontSize="11"
                        Background="{DynamicResource Brush.BorderSecondary}" Foreground="{DynamicResource Brush.ForegroundTertiary}"
                        BorderThickness="0" Cursor="Hand"
                        Click="BrowseKbDir_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="IndexKbBtn" Grid.Column="0"
                        Content="建立索引" Padding="12,6"
                        FontSize="12" Cursor="Hand"
                        Background="{DynamicResource Brush.BorderSecondary}" Foreground="{DynamicResource Brush.ForegroundSecondary}"
                        BorderThickness="0"
                        Click="IndexKb_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
                <TextBlock x:Name="KbStatus" Grid.Column="1"
                           FontSize="12" Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.ForegroundMuted}"
                           TextWrapping="Wrap" />
            </Grid>

            <TextBlock FontSize="10" Foreground="{DynamicResource Brush.ForegroundMuted}"
                       Text="选择包含 .md/.txt/.pdf 文件的目录，建立索引后 AI 可搜索你的本地文档。" />

            <TextBlock FontSize="11" Foreground="{DynamicResource Brush.ForegroundMuted}"
                       Margin="0,6,0,0"
                       Text="配置修改后需重启应用生效" />

            <!-- Model Management -->
            <Border Height="1" Background="{DynamicResource Brush.BorderSecondary}" Margin="0,14,0,14" />

            <TextBlock FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.ForegroundTertiary}" Text="模型管理"
                       Margin="0,0,0,10" />

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ModelStatusText" Grid.Column="0"
                           FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.ForegroundMuted}"
                           TextWrapping="Wrap" />
                <Button Grid.Column="1" x:Name="OpenModelDirBtn"
                        Content="打开目录" Width="80" Padding="6,2"
                        Margin="8,0,0,0" FontSize="11"
                        Background="{DynamicResource Brush.BorderSecondary}" Foreground="{DynamicResource Brush.ForegroundTertiary}"
                        BorderThickness="0" Cursor="Hand"
                        Click="OpenModelDir_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="UploadModelBtn" Grid.Column="0"
                        Content="上传模型" Padding="12,6"
                        FontSize="12" Cursor="Hand"
                        Background="{DynamicResource Brush.BorderSecondary}" Foreground="{DynamicResource Brush.ForegroundSecondary}"
                        BorderThickness="0"
                        Click="UploadModel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="DownloadModelBtn" Grid.Column="1"
                        Content="下载模型" Padding="12,6"
                        Margin="8,0,0,0"
                        FontSize="12" Cursor="Hand"
                        Background="{DynamicResource Brush.BorderSecondary}" Foreground="{DynamicResource Brush.ForegroundSecondary}"
                        BorderThickness="0"
                        Click="DownloadModel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
                <TextBlock x:Name="ModelOpStatus" Grid.Column="2"
                           FontSize="12" Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.ForegroundMuted}"
                           TextWrapping="Wrap" />
            </Grid>

            <TextBlock FontSize="10" Foreground="{DynamicResource Brush.ForegroundMuted}"
                       Text="上传：选择本地 .gguf 文件；下载：从镜像源获取默认模型（约 350 MB）。" />
        </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Width="80" Padding="8,6"
                    Margin="0,0,10,0"
                    Background="{DynamicResource Brush.BorderSecondary}" Foreground="{DynamicResource Brush.ForegroundSecondary}"
                    BorderThickness="0" FontSize="12" Cursor="Hand"
                    Click="Cancel_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="保存" Width="80" Padding="8,6"
                    FontSize="12" FontWeight="SemiBold"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="Save_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" CornerRadius="6"
                                Padding="18,6"
                                Background="{DynamicResource Brush.AccentBtn}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
