<Window x:Class="PersonalAssistant.Features.Plugins.PluginMarketplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="插件市场"
        Width="520" SizeToContent="Height" MaxHeight="580"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Background="{DynamicResource Brush.BackgroundPrimary}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.ForegroundPrimary}"
                   Text="插件市场" Margin="0,0,0,16" />

        <!-- Plugin List -->
        <ScrollViewer Grid.Row="1" MaxHeight="420" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Loading -->
                <TextBlock x:Name="LoadingText"
                           Foreground="{DynamicResource Brush.ForegroundMuted}"
                           FontSize="12" Text="加载中..." Visibility="Visible" />

                <!-- Results -->
                <ItemsControl x:Name="PluginsItems" Visibility="Collapsed">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource Brush.BackgroundSecondary}"
                                    CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.ForegroundPrimary}" />
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource Brush.ForegroundSecondary}"
                                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource Brush.ForegroundMuted}"
                                                   Margin="0,2,0,0">
                                            <Run Text="作者: " />
                                            <Run Text="{Binding Author}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="安装"
                                            FontSize="12" Width="60" Height="30"
                                            VerticalAlignment="Center" Margin="12,0,0,0"
                                            Foreground="White" BorderThickness="0"
                                            Cursor="Hand" Tag="{Binding}"
                                            Click="Install_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6" />
                                            </Style>
                                        </Button.Resources>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="6" Padding="8,3"
                                                        Background="{DynamicResource Brush.AccentBtn}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Error / Empty -->
        <TextBlock x:Name="MessageText" Grid.Row="2"
                   FontSize="12" Foreground="{DynamicResource Brush.ForegroundMuted}"
                   Margin="0,8,0,0" Visibility="Collapsed" />
    </Grid>
</Window>
