<Window x:Class="PersonalAssistant.Features.Plugins.PluginManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="插件管理"
        Width="520" SizeToContent="Height" MaxHeight="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow"
        Background="{DynamicResource Brush.BackgroundPrimary}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource Brush.ForegroundPrimary}" Text="插件管理"
                   Margin="0,0,0,16" />

        <!-- Plugin List -->
        <ScrollViewer Grid.Row="1" MaxHeight="440"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PluginsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource Brush.BackgroundSecondary}" CornerRadius="8"
                                Padding="12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Plugin Info -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.ForegroundPrimary}" />
                                        <TextBlock Text="{Binding Type}"
                                                   FontSize="11" Margin="8,0,0,0"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="内置">
                                                            <Setter Property="Foreground" Value="#6B7280" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="外部">
                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.AccentStart}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Description -->
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Brush.ForegroundMuted}"
                                               Margin="0,2,0,2"
                                               TextWrapping="Wrap"
                                               MaxWidth="380" />

                                    <!-- Tool Tags -->
                                    <ItemsControl ItemsSource="{Binding ToolNames}"
                                                  Margin="0,2,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel MaxWidth="360" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource Brush.BorderSecondary}"
                                                        CornerRadius="4"
                                                        Padding="4,1" Margin="0,0,4,2">
                                                    <TextBlock Text="{Binding}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource Brush.ForegroundTertiary}" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Source File (external only) -->
                                    <TextBlock Text="{Binding SourceFile}"
                                               FontSize="10" FontStyle="Italic"
                                               Foreground="{DynamicResource Brush.ForegroundMuted}" Margin="0,2,0,0"
                                               Visibility="{Binding HasSourceFile,
                                                   Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>

                                <!-- Enable/Disable -->
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding IsEnabled}"
                                          VerticalAlignment="Center"
                                          Margin="12,0"
                                          Checked="PluginCheckBox_Changed"
                                          Unchecked="PluginCheckBox_Changed" />

                                <!-- Delete (external only) -->
                                <Button Grid.Column="2"
                                        Content="删除" FontSize="11"
                                        VerticalAlignment="Center"
                                        Background="#EF4444" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Padding="10,4"
                                        Visibility="{Binding HasSourceFile,
                                            Converter={StaticResource BoolToVisibility}}"
                                        Click="DeletePlugin_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4" />
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Restart Tip -->
        <TextBlock x:Name="RestartTip" Grid.Row="2"
                   Text="插件状态变更后需重启应用生效"
                   FontSize="12" Foreground="{DynamicResource Brush.StatusOffline}"
                   Margin="0,10,0,0" Visibility="Collapsed" />

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="导入插件" Padding="12,6"
                    Margin="0,0,10,0"
                    Background="{DynamicResource Brush.BorderSecondary}" Foreground="{DynamicResource Brush.ForegroundSecondary}"
                    BorderThickness="0" FontSize="12" Cursor="Hand"
                    Click="ImportPlugin_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="浏览市场" Padding="12,6"
                    Margin="0,0,10,0"
                    Background="{DynamicResource Brush.BorderSecondary}" Foreground="{DynamicResource Brush.ForegroundSecondary}"
                    BorderThickness="0" FontSize="12" Cursor="Hand"
                    Click="OpenMarketplace_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="关闭" Width="80" Padding="8,6"
                    FontSize="12" FontWeight="SemiBold"
                    Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="Close_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </Button.Resources>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" CornerRadius="6"
                                Padding="18,6"
                                Background="{DynamicResource Brush.AccentBtn}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
