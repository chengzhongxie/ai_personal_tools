<Window x:Class="PersonalAssistant.Features.Clipboard.Views.StickyNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快速便签"
        Width="320" Height="280"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#FFFAEBA0"
            BorderBrush="#FFE0D070"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Margin="0,0,0,6">
                <TextBlock Text="快速便签"
                           FontSize="12" FontWeight="Bold"
                           Foreground="#FF8B7355" />
                <Button x:Name="CloseButton"
                        Content="✕"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#FF8B7355"
                        FontSize="14"
                        Cursor="Hand"
                        Click="CloseButton_Click"
                        Padding="4,0" />
            </Grid>

            <!-- 文本编辑区 -->
            <TextBox x:Name="NoteTextBox"
                     Grid.Row="1"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="13"
                     FontFamily="Microsoft YaHei"
                     Background="#FFFEF8E0"
                     BorderBrush="#FFE0D070"
                     BorderThickness="1"
                     Padding="6" />

            <!-- 底部信息 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                <TextBlock x:Name="SavedIndicator"
                           Text="自动保存"
                           FontSize="10"
                           Foreground="#FF8B7355"
                           VerticalAlignment="Center" />
                <Button x:Name="ClearButton"
                        Content="清空"
                        HorizontalAlignment="Right"
                        FontSize="11"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#FF8B7355"
                        Cursor="Hand"
                        Click="ClearButton_Click"
                        Padding="6,2" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
