<UserControl x:Class="PersonalAssistant.Features.Widgets.WidgetCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="260">
    <Border Background="{DynamicResource Brush.BackgroundSecondary}"
            BorderBrush="{DynamicResource Brush.BorderSecondary}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
        <StackPanel>
            <TextBlock x:Name="TitleText"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.ForegroundTertiary}"
                       Margin="0,0,0,8" />
            <ContentPresenter x:Name="ContentHost" />
        </StackPanel>
    </Border>
</UserControl>
