<UserControl x:Class="PersonalAssistant.Features.Widgets.SystemStatusWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="260">
    <Border Background="{DynamicResource Brush.BackgroundSecondary}"
            BorderBrush="{DynamicResource Brush.BorderSecondary}"
            BorderThickness="1"
            CornerRadius="10" Padding="12">
        <StackPanel>
            <TextBlock FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.ForegroundTertiary}"
                       Text="系统状态" Margin="0,0,0,6" />

            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CPU" FontSize="11"
                           Foreground="{DynamicResource Brush.ForegroundMuted}"
                           VerticalAlignment="Center" Width="30" />
                <ProgressBar Grid.Column="1" x:Name="CpuBar"
                             Height="8" Minimum="0" Maximum="100"
                             Margin="8,0" />
                <TextBlock Grid.Column="2" x:Name="CpuText"
                           FontSize="11" Width="36" TextAlignment="Right"
                           Foreground="{DynamicResource Brush.ForegroundSecondary}" />
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="内存" FontSize="11"
                           Foreground="{DynamicResource Brush.ForegroundMuted}"
                           VerticalAlignment="Center" Width="30" />
                <ProgressBar Grid.Column="1" x:Name="MemBar"
                             Height="8" Minimum="0" Maximum="100"
                             Margin="8,0" />
                <TextBlock Grid.Column="2" x:Name="MemText"
                           FontSize="11" Width="48" TextAlignment="Right"
                           Foreground="{DynamicResource Brush.ForegroundSecondary}" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
