<UserControl x:Class="PersonalAssistant.Features.Widgets.WeatherWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="260">
    <Border Background="{DynamicResource Brush.BackgroundSecondary}"
            BorderBrush="{DynamicResource Brush.BorderSecondary}"
            BorderThickness="1"
            CornerRadius="10" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.ForegroundTertiary}"
                       Text="天气" Margin="0,0,0,6" />

            <StackPanel Grid.Row="1">
                <TextBlock x:Name="WeatherInfo" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.ForegroundPrimary}"
                           Text="--" />
                <TextBlock x:Name="WeatherLocation" FontSize="11"
                           Foreground="{DynamicResource Brush.ForegroundMuted}"
                           Text="加载中..." Margin="0,2,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
