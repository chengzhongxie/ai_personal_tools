<UserControl x:Class="PersonalAssistant.Features.Widgets.TodoWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="260">
    <Border Background="{DynamicResource Brush.BackgroundSecondary}"
            BorderBrush="{DynamicResource Brush.BorderSecondary}"
            BorderThickness="1"
            CornerRadius="10" Padding="12">
        <StackPanel>
            <TextBlock FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.ForegroundTertiary}"
                       Text="待办" Margin="0,0,0,6" />

            <ItemsControl x:Name="TodoList" MaxHeight="200" Margin="0,0,0,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsDone}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,6,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Text}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.ForegroundSecondary}" />
                            <Button Grid.Column="2" Content="X"
                                    FontSize="10" Width="20" Height="20"
                                    Padding="0" BorderThickness="0"
                                    Background="Transparent"
                                    Foreground="{DynamicResource Brush.ForegroundSubtle}"
                                    Cursor="Hand" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewTodoBox" Grid.Column="0"
                         Padding="6,4" FontSize="11"
                         Background="{DynamicResource Brush.BackgroundSecondary}"
                         Foreground="{DynamicResource Brush.ForegroundPrimary}"
                         BorderBrush="{DynamicResource Brush.BorderSecondary}"
                         CaretBrush="{DynamicResource Brush.InputCaret}"
                         KeyDown="NewTodoBox_KeyDown" />
                <Button Grid.Column="1" Content="+" Width="24" Height="24"
                        Padding="0" Margin="6,0,0,0"
                        FontSize="14" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        Foreground="{DynamicResource Brush.ForegroundPrimary}"
                        Background="{DynamicResource Brush.BorderSecondary}"
                        Click="AddTodo_Click" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
