<UserControl x:Class="PersonalAssistant.Features.Chat.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:helpers="clr-namespace:PersonalAssistant.Infrastructure.Common.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="900"
             Background="#0B0E14">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />

        <!-- 用户消息气泡渐变 -->
        <LinearGradientBrush x:Key="UserBubbleBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3B82F6" Offset="0" />
            <GradientStop Color="#6366F1" Offset="1" />
        </LinearGradientBrush>

        <!-- 发送按钮渐变 -->
        <LinearGradientBrush x:Key="SendBtnBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#3B82F6" Offset="0" />
            <GradientStop Color="#6366F1" Offset="1" />
        </LinearGradientBrush>

        <!-- 发送按钮悬停渐变 -->
        <LinearGradientBrush x:Key="SendBtnHoverBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#4F8EF7" Offset="0" />
            <GradientStop Color="#7B73F5" Offset="1" />
        </LinearGradientBrush>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,8" Background="#131720"
                BorderBrush="#1E2430" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Foreground="#6B7280" FontSize="11"
                               Text="DeepSeek AI · 文件读写 · 命令执行 · 网页抓取" />
                </StackPanel>

                <!-- 状态指示灯 -->
                <Border Grid.Column="1" Width="8" Height="8"
                        CornerRadius="4" Background="#22C55E"
                        VerticalAlignment="Center" Margin="0,0,12,0" />
            </Grid>
        </Border>

        <!-- Messages Area -->
        <ScrollViewer Grid.Row="1" x:Name="MessageScroll"
                      VerticalScrollBarVisibility="Hidden"
                      Background="#0B0E14">
            <ItemsControl ItemsSource="{Binding ViewModel.Messages}"
                          Margin="16,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <!-- 气泡最大宽度约束 -->
                            <Border Padding="14,10"
                                    CornerRadius="12"
                                    MaxWidth="580">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <!-- 用户消息：蓝色渐变，右对齐 -->
                                            <DataTrigger Binding="{Binding Role}" Value="User">
                                                <Setter Property="Background"
                                                        Value="{StaticResource UserBubbleBrush}" />
                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                            </DataTrigger>

                                            <!-- AI 回复：深色卡片，左对齐 -->
                                            <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                                <Setter Property="Background" Value="#1A1F2E" />
                                                <Setter Property="HorizontalAlignment" Value="Left" />
                                                <Setter Property="BorderBrush" Value="#2A3040" />
                                                <Setter Property="BorderThickness" Value="1" />
                                            </DataTrigger>

                                            <!-- 系统/工具：居中半透明 -->
                                            <DataTrigger Binding="{Binding Role}" Value="System">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Role}" Value="Tool">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel>
                                    <TextBox Text="{Binding Content, Mode=OneWay}"
                                             TextWrapping="Wrap"
                                             IsReadOnly="True"
                                             Cursor="IBeam"
                                             BorderThickness="0"
                                             Padding="0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="User">
                                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                                        <Setter Property="FontSize" Value="13.5" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                                        <Setter Property="Foreground" Value="#D1D5DB" />
                                                        <Setter Property="FontSize" Value="13.5" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="System">
                                                        <Setter Property="Foreground" Value="#6B7280" />
                                                        <Setter Property="FontSize" Value="11" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="Tool">
                                                        <Setter Property="Foreground" Value="#6B7280" />
                                                        <Setter Property="FontSize" Value="11" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <!-- 时间戳 -->
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                               FontSize="10"
                                               Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="User">
                                                        <Setter Property="Foreground" Value="#93C5FD" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                                        <Setter Property="Foreground" Value="#4B5563" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- InfoBar 错误提示 -->
        <ui:InfoBar Grid.Row="2"
                    Margin="16,0,16,4"
                    IsOpen="{Binding ViewModel.ShowInfoBar}"
                    Title="提示"
                    Message="{Binding ViewModel.InfoBarMessage}"
                    Severity="{Binding ViewModel.InfoBarSeverity}"
                    IsClosable="True" />

        <!-- Input Area -->
        <Border Grid.Row="3" Padding="16,12" Background="#131720"
                BorderBrush="#1E2430" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 输入框 -->
                <Border Grid.Column="0" CornerRadius="8"
                        Background="#1A1F2E"
                        BorderBrush="#2A3040" BorderThickness="1"
                        Padding="12,0">
                    <TextBox x:Name="InputTextBox"
                             Text="{Binding ViewModel.InputText, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center"
                             MinHeight="36"
                             Background="Transparent"
                             Foreground="#E8ECF1"
                             CaretBrush="#3B82F6"
                             BorderThickness="0"
                             FontSize="13"
                             PreviewKeyDown="InputTextBox_PreviewKeyDown" />
                </Border>

                <!-- 加载动画 -->
                <ui:ProgressRing Grid.Column="1"
                                 Margin="10,0,0,0"
                                 Width="20" Height="20"
                                 IsIndeterminate="{Binding ViewModel.IsWorking}"
                                 Visibility="{Binding ViewModel.IsWorking, Converter={StaticResource BoolToVis}}" />

                <!-- 发送按钮 -->
                <Button Grid.Column="2"
                        Margin="10,0,0,0"
                        Padding="18,0"
                        MinHeight="38"
                        Command="{Binding ViewModel.SendCommand}"
                        Foreground="White"
                        FontSize="13"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8" />
                        </Style>
                    </Button.Resources>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" CornerRadius="8"
                                    Background="{StaticResource SendBtnBrush}"
                                    Padding="18,0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder"
                                            Property="Background"
                                            Value="{StaticResource SendBtnHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    发送
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
