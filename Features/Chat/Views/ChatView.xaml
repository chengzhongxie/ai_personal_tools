<UserControl x:Class="PersonalAssistant.Features.Chat.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:helpers="clr-namespace:PersonalAssistant.Infrastructure.Common.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="900"
             Background="{DynamicResource Brush.BackgroundDeep}">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <helpers:MarkdownToFlowDocumentConverter x:Key="MarkdownToDoc" />

        <!-- 输入框专用样式：绕过 WPF-UI 模板内部元素的深色背景，使用简易模板 -->
        <Style x:Key="CleanInputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Brush.BackgroundSecondary}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundPrimary}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Brush.AccentStart}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Background="Transparent" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,8"
                Background="{DynamicResource Brush.BackgroundPrimary}"
                BorderBrush="{DynamicResource Brush.BorderPrimary}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource Brush.ForegroundMuted}" FontSize="11"
                               Text="DeepSeek AI · 文件读写 · 命令执行 · 网页抓取" />
                </StackPanel>

                <!-- Token 用量显示 -->
                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                           FontSize="10" Foreground="{DynamicResource Brush.ForegroundSubtle}"
                           Margin="0,0,16,0"
                           Text="{Binding ViewModel.TokenDisplay}" />

                <!-- 离线指示灯 -->
                <Border Grid.Column="2" VerticalAlignment="Center"
                        Margin="0,0,4,0"
                        Visibility="{Binding ViewModel.IsOffline, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="{DynamicResource Brush.StatusOffline}">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1.0" To="0.3"
                                                             Duration="0:0:1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                    </Grid>
                </Border>

                <!-- 在线状态指示灯 -->
                <Border Grid.Column="2" Width="8" Height="8"
                        CornerRadius="4" Background="{DynamicResource Brush.StatusOnline}"
                        VerticalAlignment="Center" Margin="0,0,12,0"
                        Visibility="{Binding ViewModel.IsOffline, Converter={StaticResource InvBoolToVis}}" />
            </Grid>
        </Border>

        <!-- Messages Area -->
        <ScrollViewer Grid.Row="1" x:Name="MessageScroll"
                      VerticalScrollBarVisibility="Hidden"
                      Background="{DynamicResource Brush.BackgroundDeep}">
            <ItemsControl ItemsSource="{Binding ViewModel.Messages}"
                          Margin="16,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <!-- 气泡最大宽度约束 -->
                            <Border Padding="14,10"
                                    CornerRadius="12"
                                    MaxWidth="580">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <!-- 用户消息：蓝色渐变，右对齐 -->
                                            <DataTrigger Binding="{Binding Role}" Value="User">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource Brush.UserBubble}" />
                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                            </DataTrigger>

                                            <!-- AI 回复：深色卡片，左对齐 -->
                                            <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                                <Setter Property="Background" Value="{DynamicResource Brush.BackgroundSecondary}" />
                                                <Setter Property="HorizontalAlignment" Value="Left" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSecondary}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                            </DataTrigger>

                                            <!-- 系统/工具：居中半透明 -->
                                            <DataTrigger Binding="{Binding Role}" Value="System">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Role}" Value="Tool">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel>
                                    <FlowDocumentScrollViewer
                                        Document="{Binding Content, Mode=OneWay, Converter={StaticResource MarkdownToDoc}}"
                                        BorderThickness="0" Padding="0"
                                        HorizontalScrollBarVisibility="Hidden"
                                        VerticalScrollBarVisibility="Auto"
                                        MaxHeight="400">
                                        <FlowDocumentScrollViewer.Style>
                                            <Style TargetType="FlowDocumentScrollViewer">
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundSecondary}" />
                                                <Setter Property="FontSize" Value="13.5" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="User">
                                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="System">
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}" />
                                                        <Setter Property="FontSize" Value="11" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="Tool">
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundMuted}" />
                                                        <Setter Property="FontSize" Value="11" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </FlowDocumentScrollViewer.Style>
                                    </FlowDocumentScrollViewer>

                                    <!-- 时间戳 -->
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                               FontSize="10"
                                               Margin="0,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Role}" Value="User">
                                                        <Setter Property="Foreground" Value="#93C5FD" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Role}" Value="Assistant">
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.ForegroundSubtle}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- 错误消息标记 -->
                                    <Border CornerRadius="4" Padding="8,4" Margin="0,6,0,0"
                                            Background="#1FEF4444" BorderBrush="#33EF4444" BorderThickness="1"
                                            Visibility="{Binding IsError, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="发生错误"
                                                   Foreground="#EF4444" FontSize="11" />
                                    </Border>

                                    <!-- 工具调用列表 -->
                                    <ItemsControl ItemsSource="{Binding ToolCalls}"
                                                  Margin="0,6,0,0"
                                                  DataContext="{Binding}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ToolCalls.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="6,3" Margin="0,1"
                                                        Background="{DynamicResource Brush.BackgroundDeep}">
                                                    <TextBlock Text="{Binding}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource Brush.ForegroundMuted}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="540" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- InfoBar 错误提示 -->
        <ui:InfoBar Grid.Row="2"
                    Margin="16,0,16,4"
                    IsOpen="{Binding ViewModel.ShowInfoBar}"
                    Title="提示"
                    Message="{Binding ViewModel.InfoBarMessage}"
                    Severity="{Binding ViewModel.InfoBarSeverity}"
                    IsClosable="True" />

        <!-- Input Area -->
        <Border Grid.Row="3" Padding="16,12"
                Background="{DynamicResource Brush.BackgroundPrimary}"
                BorderBrush="{DynamicResource Brush.BorderPrimary}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 输入框 -->
                <Border Grid.Column="0" CornerRadius="8"
                        Background="{DynamicResource Brush.BackgroundSecondary}"
                        BorderBrush="{DynamicResource Brush.BorderSecondary}" BorderThickness="1"
                        Padding="12,0">
                    <TextBox x:Name="InputTextBox"
                             Style="{StaticResource CleanInputStyle}"
                             Text="{Binding ViewModel.InputText, UpdateSourceTrigger=PropertyChanged}"
                             MinHeight="36"
                             FontSize="13"
                             PreviewKeyDown="InputTextBox_PreviewKeyDown" />
                </Border>

                <!-- 取消按钮（流式响应进行中时可见） -->
                <Button Grid.Column="1"
                        Margin="10,0,0,0"
                        Padding="12,0"
                        MinHeight="36"
                        Command="{Binding ViewModel.CancelCommand}"
                        Foreground="IndianRed"
                        FontSize="12"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Visibility="{Binding ViewModel.IsWorking, Converter={StaticResource BoolToVis}}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6" />
                        </Style>
                    </Button.Resources>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" CornerRadius="6"
                                    Background="#7F1D1D" Padding="12,6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder"
                                            Property="Background"
                                            Value="#991B1B" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    &#x2715; 取消
                </Button>

                <!-- 发送按钮 -->
                <Button Grid.Column="2"
                        Margin="10,0,0,0"
                        Padding="18,0"
                        MinHeight="38"
                        Command="{Binding ViewModel.SendCommand}"
                        Foreground="White"
                        FontSize="13"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        VerticalAlignment="Center">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8" />
                        </Style>
                    </Button.Resources>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" CornerRadius="8"
                                    Background="{DynamicResource Brush.SendBtn}"
                                    Padding="18,0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder"
                                            Property="Background"
                                            Value="{DynamicResource Brush.SendBtnHover}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    发送
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
